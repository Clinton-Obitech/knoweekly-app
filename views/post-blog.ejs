<!DOCTYPE html>
<html lang="en">
    <%- include("partials/head.ejs") %>
<body>
    <%- include("partials/admin-header.ejs") %>

    <nav class="admin-nav">
    <a href="/admin/dashboard">dashboard</a>
    <a href="/manage/blog">manage blog</a>
    </nav>

    <main class="admin-post-blog">
        <h1><%= editBlog ? "update blog" : "post blogs" %></h1>

        <form action="<%= editBlog ? '/update/'+ editBlog.id +'/blog' : '/post/blog' %>"  
            method="POST"
            enctype="multipart/form-data"
            onsubmit="disableSubmitButton()"
            >
            <select name="country">
                <option value="<%= editBlog ? editBlog.country : "" %>">
                    <%= editBlog ? editBlog.country : "choose country" %>
                </option>
                <option value="usa">united states</option>
                <option value="uk">united kingdom</option>
                <option value="ca">canada</option>
                <option value="au">australia</option>
            </select>

            <select name="category">
                <option value="<%= editBlog ? editBlog.category : "" %>">
                    <%= editBlog ? editBlog.category : "choose category" %>
                </option>
                <option value="politics">politics</option>
                <option value="finance">finance</option>
                <option value="insurance">insurance</option>
                <option value="technology">technology</option>
                <option value="education">education & careers</option>
                <option value="realestate">real estate</option>
                <option value="legal">legal</option>
                <option value="health">health</option>
                <option value="sport">sport</option>
            </select>

            <input type="text" 
            name="title" 
            placeholder="title"
            value="<%= editBlog ? editBlog.title : "" %>"
            />

            <input type="file" name="image" accept="image/*" />

            <textarea 
            name="content"
            ><%= editBlog ? editBlog.content : "content" %>
            </textarea>

            <button type="submit"><%= editBlog ? "update" : "post" %></button>
        </form>

        <% if (locals.message) {%>
            <p class="message"><%= message %></p>
        <% } %>

    </main>
    
    <%- include("partials/footer.ejs") %>
    <script src="/js/script.js"></script>
    <script>
        
        document.querySelector("form").addEventListener("submit", function() {
            document.querySelector("form > button").innerHTML = "...";
        })

    </script>
</body>
</html>