<!DOCTYPE html>
<html lang="en">
    <%- include("partials/head.ejs") %>
<body>
    <%- include("partials/admin-header.ejs") %>
    <main class="admin-auth">
        <h1>create admin</h1>
        <form id="createAdminForm" action="/create/admin" method="POST" onsubmit="disableSubmitButton()">

            <label><i class="fa-solid fa-user"></i>
            <input type="text" name="username" placeholder="username" />
            </label>
            <label><i class="fa-solid fa-envelope"></i>
            <input type="email" name="email" placeholder="email" />
            </label>
            <label><i class="fa-solid fa-lock"></i>
            <input type="password" name="password" placeholder="password" />
            </label>

            <button id="btn" type="submit">create</button>

        </form>

        <% if (locals.message) {%>
            <p class="message"><%= message %></p>
        <% } %>
    </main>

    <%- include("partials/footer.ejs") %>
    <script>
        
        document.querySelector("form").addEventListener("submit", function() {
            document.querySelector("form > button").innerHTML = "creating...";
        })

    </script>
    <script src="/js/script"></script>
</body>
</html>