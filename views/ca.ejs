<!DOCTYPE html>
<html lang="en">
    <%- include("partials/head.ejs") %>
<body>
    <%- include("partials/header.ejs") %>
    <main class="public-blogs ca">
        <h1>canada</h1>

        <nav>
            <a href="/">home</a>
            <a href="/ca/blog/politics">politics</a>
            <a href="/ca/blog/finance">finance</a>
            <a href="/ca/blog/insurance">insurance</a>
            <a href="/ca/blog/technology">technology</a>
            <a href="/ca/blog/realestate">real estate</a>
            <a href="/ca/blog/education">education & career</a>
            <a href="/ca/blog/legal">legal</a>
            <a href="/ca/blog/health">health</a>
            <a href="/ca/blog/sport">sport</a>
        </nav>

        <form id="dateForm" action="<%= locals.blogs.length > 0 ? '/ca/blog/' + locals.blogs[0].category : ''%>" 
            method="GET"
            onsubmit="disableSubmitButton()"
            >
            <input type="date" id="date" name="date" 
            value="<%= locals.blogs.length > 0 ? locals.blogs[0].date : locals.date  %>" />

            <button type="submit">Go</button>
        </form>

        <section class="blogs">
            <% if (locals.blogs.length > 0) {%>
                <h2><%= !locals.all ? blogs[0].category : "All"%></h2>
                <% blogs.forEach(blog => { %>
                    <h2><%= locals.all ? blog.category : null%></h2>
                    <article>
                        <span class="date"><%= new Date(blog.date).toLocaleDateString('en-GB', { 
                            day: 'numeric',
                            month: 'long',
                            year: 'numeric'
                        }) %></span>
                        <h2><%= blog.title %></h2>
                        <img src="<%= blog.image %>" />
                        <span>posted by <%= blog.author %></span>
                        <p><%= blog.content %></p>
                        <button>
                            continue reading
                        </button>
                    </article>
              <%  }) %>
            <% } else { %>
                <p class="not-found">no post found</p>
                <% } %>
        </section>

    </main>
    
    <%- include("partials/footer.ejs") %>
    <script src="/js/script.js"></script>
    <script>
        document.getElementById("dateForm").addEventListener("submit", function() {
        document.querySelector("#dateForm > button").innerHTML = "loading...";
    })
    </script>
</body>
</html>